# =========================
# Core timeouts
# =========================

FETCH_TIMEOUT=30

# =========================
# Auto-wait (content stability detection)
# =========================

# Poll interval in seconds (default: 0.25)
AUTO_WAIT_POLL_INTERVAL=0.25

# Minimum stable duration in seconds (default: 1.0)
AUTO_WAIT_MIN_STABLE_SECONDS=1.0

# Edge chars to compare for stability (default: 200)
AUTO_WAIT_SAMPLE_EDGE_CHARS=200

DEFAULT_MAX_LENGTH=8000

# =========================
# Extraction / LLM
# =========================

ENABLE_PROMPT_EXTRACTION=true
PROMPT_INPUT_MAX_CHARS=64000

MAX_FIND_MATCHES=12
FIND_SNIPPET_MAX_CHARS=240

# Schema language: zh / en
SCHEMA_LANGUAGE=zh

# =========================
# Browser / session
# =========================

# chrome / msedge / chromium
BROWSER_CHANNEL=chrome

# auth (recommended) / profile (legacy)
BROWSER_SESSION_MODE=auth

# auth mode storage
BROWSER_AUTH_STORAGE_STATE=~/.advanced-fetch-auth/storage_state.json

# profile mode dir (only used if BROWSER_SESSION_MODE=profile)
BROWSER_PROFILE_DIR=~/.advanced-fetch-profile

# Leave empty to use system defaults
BROWSER_LOCALE=
BROWSER_TIMEZONE_ID=
BROWSER_COLOR_SCHEME=light

BROWSER_VIEWPORT_WIDTH=1366
BROWSER_VIEWPORT_HEIGHT=768

ENABLE_AUTH_STEALTH=true

INTERVENTION_TIMEOUT_SECONDS=600

# =========================
# Proxy
# =========================

ENABLE_PROXY=true

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# =========================
# Env loading
# =========================

# Optional: explicitly specify env file path
ADVANCED_FETCH_ENV_FILE=

# =========================
# Misc
# =========================

# Ignore HTTPS certificate errors
IGNORE_SSL_ERRORS=false
