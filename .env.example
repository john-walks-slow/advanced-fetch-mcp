DEFAULT_TIMEOUT=10
STATIC_FETCH_TIMEOUT=10

BROWSER_CHANNEL=chrome
# Strongly recommended: keep this outside the repo so browser state does not dirty git.
BROWSER_PROFILE_DIR=
# Optional: copy login/session-related browser data from an existing profile.
BROWSER_PROFILE_TEMPLATE_DIR=

ENABLE_PROMPT_EXTRACTION=true
PROMPT_INPUT_MAX_CHARS=16000
PROMPT_OUTPUT_MAX_TOKENS=1200

MAX_FIND_MATCHES=8
FIND_SNIPPET_MAX_CHARS=240
